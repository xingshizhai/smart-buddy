CONFIG_ESPTOOLPY_FLASHSIZE_16MB=y
CONFIG_ESPTOOLPY_FLASHMODE_QIO=y

CONFIG_ESP_DEFAULT_CPU_FREQ_MHZ_240=y

CONFIG_SPIRAM=y
CONFIG_SPIRAM_MODE_OCT=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_SPIRAM_IGNORE_NOTFOUND=y
CONFIG_SPIRAM_MALLOC_ALWAYSINTERNAL=1024
CONFIG_SPIRAM_TRY_ALLOCATE_WIFI_LWIP=y
CONFIG_SPIRAM_MALLOC_RESERVE_INTERNAL=8192

CONFIG_PARTITION_TABLE_TWO_OTA_LARGE=y

CONFIG_ESP_WIFI_STATIC_RX_BUFFER_NUM=3
CONFIG_ESP_WIFI_DYNAMIC_RX_BUFFER_NUM=6
CONFIG_ESP_WIFI_RX_BA_WIN=3
CONFIG_LWIP_TCPIP_RECVMBOX_SIZE=16
CONFIG_MBEDTLS_DYNAMIC_FREE_CONFIG_DATA=y

CONFIG_ESP32S3_INSTRUCTION_CACHE_32KB=y
CONFIG_ESP32S3_DATA_CACHE_LINE_64B=y

CONFIG_ESP_SYSTEM_EVENT_TASK_STACK_SIZE=4096

CONFIG_USB_HOST_CONTROL_TRANSFER_MAX_SIZE=1536

CONFIG_STT_PROVIDER_VOLCENGINE=y
# CONFIG_STT_PROVIDER_ALIYUN is not set
# CONFIG_STT_PROVIDER_CUSTOM is not set
CONFIG_VOICE_VOLCENGINE_APP_ID=""
CONFIG_VOICE_VOLCENGINE_ACCESS_TOKEN=""
CONFIG_VOICE_VOLCENGINE_SECRET_KEY=""
CONFIG_VOICE_VOLCENGINE_STT_BASE_URL="wss://openspeech.bytedance.com/api/v3/sauc/bigmodel_async"
CONFIG_VOICE_VOLCENGINE_STT_MODEL="bigmodel"
CONFIG_VOLCENGINE_STT_LANGUAGE="zh-CN"
CONFIG_VOLCENGINE_STT_ENABLE_ITN=y
CONFIG_VOLCENGINE_STT_ENABLE_PUNC=y
# CONFIG_VOLCENGINE_STT_ENABLE_NONSTREAM is not set
CONFIG_VOLCENGINE_STT_RESULT_TYPE="full"
CONFIG_VOLCENGINE_STT_END_WINDOW_SIZE_MS=800

CONFIG_TTS_PROVIDER_VOLCENGINE=y
# CONFIG_TTS_PROVIDER_ALIYUN is not set
# CONFIG_TTS_PROVIDER_CUSTOM is not set
CONFIG_VOICE_VOLCENGINE_TTS_BASE_URL="https://openspeech.bytedance.com/api/v1/tts"
CONFIG_VOICE_VOLCENGINE_TTS_VOICE=""

CONFIG_ENABLE_VOICE_GATEWAY=y
CONFIG_DEFAULT_VOICE_GATEWAY_URL=""
CONFIG_DEFAULT_VOICE_GATEWAY_TOKEN=""

CONFIG_ENABLE_BARGE_IN=y
CONFIG_VAD_SILENCE_MS=800
CONFIG_STT_TIMEOUT_MS=8000
CONFIG_TTS_TIMEOUT_MS=12000
CONFIG_AUDIO_CHUNK_MS=200
